import streamlit as st
from docxtpl import DocxTemplate
import io
from datetime import datetime

def render_report_tab():
    st.subheader("🛠️ Tạo Báo Cáo Sự Cố Kỹ Thuật")
    
    # Giao diện nhập liệu chia cột cho gọn
    with st.form("technical_report_form"):
        st.markdown("### 1. THÔNG TIN TỔNG QUÁT")
        col1, col2 = st.columns(2)
        with col1:
            ac_type = st.text_input("Loại máy bay:", value="A321")
            ac_reg = st.text_input("Số hiệu tàu bay:", placeholder="VD: VN-A677")
            flight_no = st.text_input("Số hiệu chuyến bay:", placeholder="VD: VJ517")
        with col2:
            route = st.text_input("Nơi đi - Nơi đến:", placeholder="VD: HAN-DAD")
            incident_time = st.text_input("Giờ, ngày xảy ra sự cố:", 
                                        value=datetime.now().strftime("%H:%M LT, ngày %d/%m/%Y"))

        st.markdown("### 2. MÔ TẢ SỰ CỐ")
        desc = st.text_input("Nội dung sự cố:", placeholder="VD: TAILSTRIKE DURING GO-AROUND")

        st.markdown("### 3. KHẮC PHỤC SỰ CỐ")
        action = st.text_area("Các bước đã thực hiện:", 
                             height=150,
                             placeholder="- VJ517 ĐÁP VỀ BÃI 25...\n- A677 NẰM SÂN...")

        st.markdown("### XÁC NHẬN")
        reporter = st.text_input("Người báo cáo (Ký tên):", placeholder="NHẬP TÊN VIẾT HOA")

        submit = st.form_submit_button("Tạo báo cáo Word")

    if submit:
        try:
            # Đường dẫn tới file word mẫu của bạn
            doc = DocxTemplate("template_bao_cao.docx")
            
            # Khớp các biến trong file Word với dữ liệu từ Form
            context = {
                "loai_tau": ac_type,
                "reg": ac_reg,
                "flight_no": flight_no,
                "route": route,
                "timing": incident_time,
                "description": desc,
                "action": action,
                "reporter": reporter
            }
            
            doc.render(context)
            
            # Xuất file ra bộ nhớ đệm
            buffer = io.BytesIO()
            doc.save(buffer)
            buffer.seek(0)
            
            st.success("Đã tạo báo cáo thành công!")
            st.download_button(
                label="📥 Tải Báo Cáo (.docx)",
                data=buffer,
                file_name=f"Report_{ac_reg}_{datetime.now().strftime('%d%m')}.docx",
                mime="application/vnd.openxmlformats-officedocument.wordprocessingml.document"
            )
        except Exception as e:
            st.error(f"Lỗi khi xử lý file: {e}")

